# NetMonitor Configuration
PORT=3000
HOST=0.0.0.0
DOMAIN=localhost
NODE_ENV=development

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# Speed test limits
MAX_SPEEDTEST_SIZE_MB=25

# Custom DNS servers (comma-separated, e.g. 8.8.8.8,1.1.1.1)
# If empty, uses system default DNS
DNS_SERVERS=

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# CORS origin (* for all, or comma-separated origins)
CORS_ORIGIN=*

# ipinfo.io API token (optional, improves IP lookup accuracy)
IPINFO_TOKEN=
